<UserControl x:Class="NexPOS.TransactionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F4F6">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- HEADER -->
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="Transaction History"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#111827"/>

                    <TextBlock x:Name="txtTransactionSubtitle"
                               Text="0 total transactions"
                               FontSize="14"
                               Foreground="#64748B"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- SUMMARY CARDS -->
                <UniformGrid Columns="3" Margin="0,0,0,20">

                    <!-- TOTAL TRANSACTIONS -->
                    <Border Background="White"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,12,0">

                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="46"
                                        Height="46"
                                        Background="#EFF6FF"
                                        CornerRadius="12"
                                        Margin="0,0,14,0">

                                    <TextBlock Text="▣"
                                               Foreground="#2563EB"
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Total Transactions"
                                               Foreground="#64748B"
                                               FontSize="13"/>

                                    <TextBlock x:Name="txtTotalTransactions"
                                               Text="0"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#2563EB"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- TODAY REVENUE -->
                    <Border Background="White"
                            CornerRadius="12"
                            Padding="20"
                            Margin="0,0,12,0">

                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="46"
                                        Height="46"
                                        Background="#DCFCE7"
                                        CornerRadius="12"
                                        Margin="0,0,14,0">

                                    <TextBlock Text="▦"
                                               Foreground="#16A34A"
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Today's Revenue"
                                               Foreground="#64748B"
                                               FontSize="13"/>

                                    <TextBlock x:Name="txtTodayRevenue"
                                               Text="₱0.00"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#00A651"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- TOTAL REVENUE -->
                    <Border Background="White"
                            CornerRadius="12"
                            Padding="20">

                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="46"
                                        Height="46"
                                        Background="#FAF5FF"
                                        CornerRadius="12"
                                        Margin="0,0,14,0">

                                    <TextBlock Text="↗"
                                               Foreground="#9333EA"
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Total Revenue"
                                               Foreground="#64748B"
                                               FontSize="13"/>

                                    <TextBlock x:Name="txtTotalRevenue"
                                               Text="₱0.00"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="#9333EA"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- SEARCH AND FILTER -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="18"
                        Margin="0,0,0,20">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#F8FAFC"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="8"
                                Height="40"
                                Margin="0,0,12,0">

                            <Grid>
                                <TextBlock Text="🔍"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           Foreground="#94A3B8"/>

                                <TextBox x:Name="txtSearch"
                                         Margin="40,0,10,0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         FontSize="14"
                                         TextChanged="Filter_Changed"/>
                            </Grid>
                        </Border>

                        <ComboBox x:Name="cmbCashier"
                                  Grid.Column="1"
                                  Height="40"
                                  SelectionChanged="Filter_Changed"/>
                    </Grid>
                </Border>

                <!-- TABLE -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="0">

                    <Grid>
                        <DataGrid x:Name="gridTransactions"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  Height="330"
                                  RowHeight="48"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Background="White"
                                  RowBackground="White"
                                  AlternatingRowBackground="White"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  FontSize="13">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#475569"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Height" Value="42"/>
                                    <Setter Property="Padding" Value="14,0,0,0"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                </Style>

                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                </Style>

                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="14,0,0,0"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="RECEIPT #"
                                                    Binding="{Binding ReceiptNo}"
                                                    Width="1.2*"/>

                                <DataGridTextColumn Header="DATE &amp; TIME"
                                                    Binding="{Binding DateTimeText}"
                                                    Width="1.6*"/>

                                <DataGridTextColumn Header="CASHIER"
                                                    Binding="{Binding Cashier}"
                                                    Width="1.3*"/>

                                <DataGridTextColumn Header="ITEMS"
                                                    Binding="{Binding TotalItems}"
                                                    Width="0.8*"/>

                                <DataGridTextColumn Header="TOTAL"
                                                    Binding="{Binding TotalText}"
                                                    Width="1*"/>

                                <DataGridTextColumn Header="CHANGE"
                                                    Binding="{Binding ChangeText}"
                                                    Width="1*"/>

                                <DataGridTemplateColumn Header="ACTION"
                                                        Width="1*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="View"
                                                    Width="70"
                                                    Height="28"
                                                    Background="#EFF6FF"
                                                    Foreground="#2563EB"
                                                    BorderThickness="0"
                                                    FontWeight="SemiBold"
                                                    Cursor="Hand"
                                                    Click="ViewTransaction_Click"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- EMPTY MESSAGE -->
                        <StackPanel x:Name="emptyPanel"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">

                            <TextBlock Text="▣"
                                       FontSize="36"
                                       Foreground="#CBD5E1"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="No transactions found"
                                       Foreground="#94A3B8"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
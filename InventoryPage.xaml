<UserControl x:Class="NexPOS.InventoryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F4F6">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- HEADER -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Inventory Management"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#111827"/>

                        <TextBlock x:Name="txtSubtitle"
                                   FontSize="14"
                                   Foreground="#64748B"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="+  Add Product"
                            Width="140"
                            Height="42"
                            Background="#00A651"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="ShowAddProduct_Click"/>
                </Grid>

                <!-- SUMMARY CARDS -->
                <UniformGrid Columns="4" Margin="0,0,0,18">

                    <Border Background="White" CornerRadius="12" Padding="18" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Total Products" Foreground="#64748B"/>
                            <TextBlock x:Name="txtTotalProducts"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#2563EB"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="12" Padding="18" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Active" Foreground="#64748B"/>
                            <TextBlock x:Name="txtActiveProducts"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#00A651"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="12" Padding="18" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Low Stock" Foreground="#64748B"/>
                            <TextBlock x:Name="txtLowStock"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#EA580C"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" CornerRadius="12" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Out of Stock" Foreground="#64748B"/>
                            <TextBlock x:Name="txtOutOfStock"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="Red"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- SEARCH AND FILTER -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="18"
                        Margin="0,0,0,18">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="170"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtSearch"
                                 Height="38"
                                 Margin="0,0,10,0"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 TextChanged="Filter_Changed"/>

                        <ComboBox x:Name="cmbCategory"
                                  Grid.Column="1"
                                  Height="38"
                                  Margin="0,0,10,0"
                                  SelectionChanged="Filter_Changed"/>

                        <ComboBox x:Name="cmbStatus"
                                  Grid.Column="2"
                                  Height="38"
                                  SelectionChanged="Filter_Changed"/>
                    </Grid>
                </Border>

                <!-- TABLE -->
                <Border Background="White"
                        CornerRadius="12"
                        Padding="0"
                        HorizontalAlignment="Stretch">

                    <DataGrid x:Name="gridProducts"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Height="430"
                              RowHeight="52"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="White"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              FontSize="13">

                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Foreground" Value="#475569"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Height" Value="42"/>
                                <Setter Property="Padding" Value="10,0,0,0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>

                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            </Style>

                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,0,0,0"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                        </DataGrid.Resources>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="CODE"
                                                Binding="{Binding ProductCode}"
                                                Width="0.8*"/>

                            <DataGridTextColumn Header="PRODUCT"
                                                Binding="{Binding ProductName}"
                                                Width="1.8*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="CATEGORY"
                                                Binding="{Binding CategoryName}"
                                                Width="1.2*"/>

                            <DataGridTextColumn Header="PRICE"
                                                Binding="{Binding PriceText}"
                                                Width="0.8*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- STOCK -->
                            <DataGridTemplateColumn Header="STOCK" Width="0.8*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Padding="8,3"
                                                MinWidth="32"
                                                Height="24"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StockLevel}" Value="Low">
                                                            <Setter Property="Background" Value="#FEF3C7"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StockLevel}" Value="Out">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock Text="{Binding StockDisplay}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#15803D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StockLevel}" Value="Low">
                                                                <Setter Property="Foreground" Value="#EA580C"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding StockLevel}" Value="Out">
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="EXPIRATION"
                                                Binding="{Binding ExpirationText}"
                                                Width="1*"/>

                            <!-- STATUS -->
                            <DataGridTemplateColumn Header="STATUS" Width="0.8*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10"
                                                Padding="8,3"
                                                Height="24"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#15803D"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- ACTIONS -->
                            <DataGridTemplateColumn Header="ACTIONS" Width="0.8*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Content="✎"
                                                    Width="26"
                                                    Height="26"
                                                    Foreground="#2563EB"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Cursor="Hand"
                                                    Margin="0,0,8,0"
                                                    Click="EditProduct_Click"/>

                                            <Button Content="🗑"
                                                    Width="26"
                                                    Height="26"
                                                    Foreground="Red"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    FontSize="13"
                                                    Cursor="Hand"
                                                    Click="DeleteProduct_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ADD / EDIT PRODUCT MODAL -->
        <Grid x:Name="ProductOverlay"
              Background="#80000000"
              Visibility="Collapsed">

            <Border Width="520"
                    Background="White"
                    CornerRadius="14"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>
                    <Grid Margin="24,20,24,18">
                        <TextBlock x:Name="txtModalTitle"
                                   Text="Add New Product"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"/>

                        <Button Content="×"
                                Width="30"
                                Height="30"
                                HorizontalAlignment="Right"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="22"
                                Foreground="#64748B"
                                Click="CloseProductModal_Click"/>
                    </Grid>

                    <Border BorderBrush="#E5E7EB"
                            BorderThickness="0,1,0,0"/>

                    <StackPanel Margin="24">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PRODUCT CODE *" FontWeight="SemiBold" Foreground="#475569"/>
                                <TextBox x:Name="txtProductCode" Height="38" Margin="0,5,0,14"/>

                                <TextBlock Text="PRODUCT NAME *" FontWeight="SemiBold" Foreground="#475569"/>
                                <TextBox x:Name="txtProductName" Height="38" Margin="0,5,0,14"/>

                                <TextBlock Text="CATEGORY *" FontWeight="SemiBold" Foreground="#475569"/>
                                <ComboBox x:Name="cmbProductCategory" Height="38" Margin="0,5,0,14"/>

                                <TextBlock Text="EXPIRATION DATE *" FontWeight="SemiBold" Foreground="#475569"/>
                                <DatePicker x:Name="dpExpirationDate" Height="38" Margin="0,5,0,14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="STATUS" FontWeight="SemiBold" Foreground="#475569"/>
                                <ComboBox x:Name="cmbProductStatus" Height="38" Margin="0,5,0,14">
                                    <ComboBoxItem Content="Active"/>
                                    <ComboBoxItem Content="Inactive"/>
                                </ComboBox>

                                <TextBlock Text="UNIT PRICE (₱) *" FontWeight="SemiBold" Foreground="#475569"/>
                                <TextBox x:Name="txtUnitPrice" Height="38" Margin="0,5,0,14"/>

                                <TextBlock Text="STOCK QTY *" FontWeight="SemiBold" Foreground="#475569"/>
                                <TextBox x:Name="txtStockQty" Height="38" Margin="0,5,0,14"/>

                                <TextBlock Text="REORDER LEVEL *" FontWeight="SemiBold" Foreground="#475569"/>
                                <TextBox x:Name="txtReorderLevel" Height="38" Margin="0,5,0,14"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnSaveProduct"
                                    Grid.Column="0"
                                    Content="Add Product"
                                    Height="42"
                                    Background="#00A651"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    BorderThickness="0"
                                    Click="SaveProduct_Click"/>

                            <Button Grid.Column="2"
                                    Content="Cancel"
                                    Height="42"
                                    Background="#E5E7EB"
                                    BorderThickness="0"
                                    Click="CloseProductModal_Click"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
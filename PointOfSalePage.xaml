<UserControl x:Class="NexPOS.PointOfSalePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F3F4F6">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE PRODUCTS -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="130"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- SEARCH AND CATEGORIES -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,0,0,1"
                    Padding="20,15">

                <StackPanel>
                    <Border Background="#F8FAFC"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="10"
                            Height="42">

                        <Grid>
                            <TextBlock Text="🔍"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="#94A3B8"/>

                            <TextBox x:Name="txtSearchProduct"
                                     Margin="40,0,10,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     TextChanged="SearchProduct_Changed"/>
                        </Grid>
                    </Border>

                    <StackPanel x:Name="categoryPanel"
                                Orientation="Horizontal"
                                Margin="0,14,0,0"/>
                </StackPanel>
            </Border>

            <!-- PRODUCT CARDS -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <WrapPanel x:Name="productPanel"
                           Margin="20"/>
            </ScrollViewer>
        </Grid>

        <!-- RIGHT SIDE CURRENT ORDER -->
        <Border Grid.Column="1"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1,0,0,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="65"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <!-- CART HEADER -->
                <Border Grid.Row="0"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,0,0,1"
                        Padding="20,0">

                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="🛒"
                                       FontSize="22"
                                       Margin="0,0,10,0"/>

                            <TextBlock Text="Current Order"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#111827"/>
                        </StackPanel>

                        <Border x:Name="cartCountBadge"
                                Background="#00A651"
                                CornerRadius="14"
                                Padding="10,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">

                            <TextBlock x:Name="txtCartCount"
                                       Text="0 items"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- CART ITEMS -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="cartPanel"
                                Margin="20"/>
                </ScrollViewer>

                <!-- TOTAL AND PAYMENT -->
                <Border Grid.Row="2"
                        BorderBrush="#E5E7EB"
                        BorderThickness="0,1,0,0"
                        Padding="20">

                    <StackPanel>
                        <Border Background="#F8FAFC"
                                CornerRadius="14"
                                Padding="18"
                                Margin="0,0,0,16">

                            <Grid>
                                <TextBlock Text="Total Amount"
                                           FontSize="16"
                                           Foreground="#475569"
                                           VerticalAlignment="Center"/>

                                <TextBlock x:Name="txtTotal"
                                           Text="₱0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#111827"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <Button Content="🛒  Process Payment"
                                Height="54"
                                Background="#00A651"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="ProcessPayment_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- CASH PAYMENT MODAL -->
        <Grid x:Name="PaymentOverlay"
              Grid.ColumnSpan="2"
              Background="#80000000"
              Visibility="Collapsed">

            <Border Width="480"
                    Background="White"
                    CornerRadius="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <!-- MODAL HEADER -->
                    <Grid Margin="28,22,28,18">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40"
                                    Height="40"
                                    Background="#DCFCE7"
                                    CornerRadius="12"
                                    Margin="0,0,12,0">

                                <TextBlock Text="💵"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Cash Payment"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="#111827"/>
                        </StackPanel>

                        <Button Content="×"
                                Width="32"
                                Height="32"
                                Background="Transparent"
                                BorderThickness="0"
                                FontSize="22"
                                Foreground="#64748B"
                                HorizontalAlignment="Right"
                                Click="ClosePayment_Click"/>
                    </Grid>

                    <Border BorderBrush="#E5E7EB"
                            BorderThickness="0,1,0,0"/>

                    <StackPanel Margin="28">

                        <Border Background="#ECFDF5"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20"
                                Margin="0,0,0,22">

                            <StackPanel>
                                <TextBlock Text="AMOUNT DUE"
                                           Foreground="#00A651"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>

                                <TextBlock x:Name="txtAmountDue"
                                           Text="₱0.00"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="#008236"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="CASH TENDERED"
                                   Foreground="#475569"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <TextBox x:Name="txtCashTendered"
                                 Height="54"
                                 FontSize="20"
                                 FontWeight="Bold"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="#00C853"
                                 BorderThickness="2"
                                 TextChanged="CashTendered_Changed"/>

                        <Grid Margin="0,12,0,18">
                            <TextBlock Text="Change"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"/>

                            <TextBlock x:Name="txtPaymentChange"
                                       Text="₱0.00"
                                       FontWeight="Bold"
                                       Foreground="#00A651"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="QUICK AMOUNTS"
                                   Foreground="#475569"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,10"/>

                        <UniformGrid Columns="3" Rows="2" Margin="0,0,0,24">
                            <Button Content="₱20" Height="46" Margin="0,0,8,10" Tag="20" Click="QuickAmount_Click"/>
                            <Button Content="₱50" Height="46" Margin="0,0,8,10" Tag="50" Click="QuickAmount_Click"/>
                            <Button Content="₱100" Height="46" Margin="0,0,0,10" Tag="100" Click="QuickAmount_Click"/>
                            <Button Content="₱200" Height="46" Margin="0,0,8,0" Tag="200" Click="QuickAmount_Click"/>
                            <Button Content="₱500" Height="46" Margin="0,0,8,0" Tag="500" Click="QuickAmount_Click"/>
                            <Button Content="₱1000" Height="46" Tag="1000" Click="QuickAmount_Click"/>
                        </UniformGrid>

                        <Button x:Name="btnCompleteTransaction"
                                Content="Complete Transaction"
                                Height="54"
                                Background="#00A651"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="CompleteTransaction_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- RECEIPT MODAL -->
        <Grid x:Name="ReceiptOverlay"
              Grid.ColumnSpan="2"
              Background="#80000000"
              Visibility="Collapsed">

            <Border Width="470"
                    MaxHeight="720"
                    Background="White"
                    CornerRadius="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="90"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="30,18,30,0">

                        <StackPanel x:Name="receiptPrintArea">
                            <TextBlock x:Name="txtReceiptText"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       Foreground="#111827"
                                       TextWrapping="NoWrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="1"
                          Margin="30,16,30,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button Content="🖨  Print Receipt"
                                Height="50"
                                Background="#111827"
                                Foreground="White"
                                FontSize="15"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="PrintReceipt_Click"/>

                        <Button Grid.Column="2"
                                Content="New Sale"
                                Height="50"
                                Background="#00A651"
                                Foreground="White"
                                FontSize="15"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="NewSale_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
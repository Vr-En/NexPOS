<Window x:Class="NexPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NexPOS"
        Height="720"
        Width="1350"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ActiveMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#078B3E"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#111827">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <!-- LOGO -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="15,20,10,10">

                    <Border Width="36"
                            Height="36"
                            Background="#00C853"
                            CornerRadius="9">

                        <TextBlock Text="▣"
                                   Foreground="White"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="NexPOS"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="15"/>

                        <TextBlock Text="Grocery POS"
                                   Foreground="#86EFAC"
                                   FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <!-- MENU -->
                <StackPanel Grid.Row="1"
                            Margin="10,10,10,0">

                    <Button x:Name="btnDashboard"
                            Content="▦  Dashboard"
                            Style="{StaticResource ActiveMenuButtonStyle}"
                            Click="Dashboard_Click"/>

                    <Button x:Name="btnInventory"
                            Content="▧  Inventory"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Inventory_Click"/>

                    <Button x:Name="btnTransactions"
                            Content="▣  Transactions"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Transactions_Click"/>

                    <Button x:Name="btnCategories"
                            Content="◇  Categories"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Categories_Click"/>

                    <Button x:Name="btnUsers"
                            Content="♙  Users"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="Users_Click"/>

                    <!--<Button x:Name="btnPOS"
                            Content="🛒  Point of Sale"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="POS_Click"/>-->
                </StackPanel>

                <!-- USER / SIGN OUT -->
                <StackPanel Grid.Row="2"
                            Margin="12">

                    <Border Background="#1F2937"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,0,12">

                        <StackPanel>
                            <TextBlock Text="Store Owner"
                                       Foreground="White"
                                       FontWeight="Bold"/>

                            <Border Background="#F59E0B"
                                    CornerRadius="8"
                                    Padding="6,2"
                                    Width="55"
                                    Margin="0,6,0,0"
                                    HorizontalAlignment="Left">

                                <TextBlock Text="Owner"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Button Content="↪  Sign Out"
                            Style="{StaticResource MenuButtonStyle}"
                            Background="Transparent"
                            Click="SignOut_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN DASHBOARD -->
        <ScrollViewer x:Name="DashboardPanel"
                      Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="22">

                <!-- HEADER -->
                <TextBlock Text="Good day, Store!"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#111827"/>

                <TextBlock Text="Here's what's happening in your store today."
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,5,0,20"/>

                <!-- TOP CARDS FIXED: 3 FULL WIDTH COLUMNS -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- TODAY SALES -->
                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}"
                            MinHeight="105">

                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Today's Sales"
                                           Foreground="#64748B"/>

                                <TextBlock x:Name="txtTodaySales"
                                           Text="₱0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#00A651"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="13"
                                    Background="#DCFCE7"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">

                                <TextBlock Text="↗"
                                           Foreground="#16A34A"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ACTIVE PRODUCTS -->
                    <Border Grid.Column="2"
                            Style="{StaticResource CardStyle}"
                            MinHeight="105">

                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Active Products"
                                           Foreground="#64748B"/>

                                <TextBlock x:Name="txtActiveProducts"
                                           Text="0"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#9333EA"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="13"
                                    Background="#FAF5FF"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">

                                <TextBlock Text="◇"
                                           Foreground="#9333EA"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- MONTHLY SALES -->
                    <Border Grid.Column="4"
                            Style="{StaticResource CardStyle}"
                            MinHeight="105">

                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Monthly Sales"
                                           Foreground="#64748B"/>

                                <TextBlock x:Name="txtMonthlySales"
                                           Text="₱0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#EA580C"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="13"
                                    Background="#FEF3C7"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">

                                <TextBlock Text="⌁"
                                           Foreground="#EA580C"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ALERTS -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LOW STOCK -->
                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}"
                            MinHeight="130">

                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32"
                                            Height="32"
                                            CornerRadius="8"
                                            Background="#FEE2E2">

                                        <TextBlock Text="⚠"
                                                   Foreground="#EF4444"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="Low Stock Alerts"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="12,7,0,0"/>
                                </StackPanel>

                                <Border Background="#FEE2E2"
                                        CornerRadius="10"
                                        Padding="8,3"
                                        HorizontalAlignment="Right">

                                    <TextBlock x:Name="txtLowStockCount"
                                               Text="0 items"
                                               Foreground="#EF4444"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="lowStockPanel"
                                        MinHeight="45">

                                <TextBlock Text="No low stock items"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- EXPIRING -->
                    <Border Grid.Column="2"
                            Style="{StaticResource CardStyle}"
                            MinHeight="130">

                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32"
                                            Height="32"
                                            CornerRadius="8"
                                            Background="#FEF3C7">

                                        <TextBlock Text="◴"
                                                   Foreground="#F59E0B"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="Expiring in 30 Days"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="12,7,0,0"/>
                                </StackPanel>

                                <Border Background="#FEF3C7"
                                        CornerRadius="10"
                                        Padding="8,3"
                                        HorizontalAlignment="Right">

                                    <TextBlock x:Name="txtExpiringCount"
                                               Text="0 items"
                                               Foreground="#F59E0B"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="expiringPanel"
                                        MinHeight="45">

                                <TextBlock Text="No products expiring soon"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RECENT TRANSACTIONS FULL WIDTH FIXED -->
                <Border Style="{StaticResource CardStyle}"
                        MinHeight="320"
                        Margin="0,0,0,20">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock Text="Recent Transactions"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       VerticalAlignment="Center"/>

                            <Button Content="View all →"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#16A34A"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    Click="Transactions_Click"/>
                        </Grid>

                        <StackPanel x:Name="recentTransactionsPanel"
                                    Grid.Row="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch">

                            <TextBlock Text="No transactions yet"
                                       Foreground="#94A3B8"
                                       HorizontalAlignment="Center"
                                       Margin="0,90,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- OTHER PAGE AREA -->
        <Grid x:Name="PagePanel"
              Grid.Column="1"
              Background="#F3F4F6"
              Visibility="Collapsed">

            <ContentControl x:Name="MainContent"/>
        </Grid>
    </Grid>
</Window>
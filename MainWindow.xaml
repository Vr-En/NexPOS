<Window x:Class="NexPOS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NexPOS"
        Height="720"
        Width="1350"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ActiveMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#078B3E"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.12"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#111827">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="15,20,10,10">
                    <Border Width="36" Height="36" Background="#00C853" CornerRadius="9">
                        <TextBlock Text="▣"
                                   Foreground="White"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="NexPOS"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="15"/>
                        <TextBlock Text="Grocery POS"
                                   Foreground="#86EFAC"
                                   FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="10,10,10,0">
                    <Button x:Name="btnDashboard"
                    Content="▦  Dashboard"
                    Style="{StaticResource ActiveMenuButtonStyle}"
                    Click="Dashboard_Click"/>

                    <Button x:Name="btnInventory"
                    Content="▧  Inventory"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="Inventory_Click"/>

                    <Button x:Name="btnPOS"
                    Content="🛒  Point of Sale"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="POS_Click"/>

                    <Button x:Name="btnTransactions"
                    Content="▣  Transactions"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="Transactions_Click"/>

                    <Button x:Name="btnCategories"
                    Content="◇  Categories"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="Categories_Click"/>

                    <Button x:Name="btnUsers"
                    Content="♙  Users"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="Users_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="12">
                    <Border Background="#1F2937"
                            CornerRadius="8"
                            Padding="15"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Store Owner"
                                       Foreground="White"
                                       FontWeight="Bold"/>

                            <Border Background="#F59E0B"
                                    CornerRadius="8"
                                    Padding="6,2"
                                    Width="55"
                                    Margin="0,6,0,0"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="Owner"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           TextAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Button Content="↪  Sign Out"
                            Style="{StaticResource MenuButtonStyle}"
                            Background="Transparent"
                            Click="SignOut_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN DASHBOARD -->
        <ScrollViewer x:Name="DashboardPanel"
                      Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22">

                <TextBlock Text="Good day, Store!"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#111827"/>

                <TextBlock Text="Here's what's happening in your store today."
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,5,0,20"/>

                <!-- TOP CARDS -->
                <UniformGrid Columns="4" Margin="0,0,0,20">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Today's Sales" Foreground="#64748B"/>
                                <TextBlock x:Name="txtTodaySales"
                                           Text="₱0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#00A651"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="13"
                                    Background="#DCFCE7"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <TextBlock Text="↗"
                                           Foreground="#16A34A"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Today's Transactions" Foreground="#64748B"/>
                                <TextBlock x:Name="txtTodayTransactions"
                                           Text="0"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#2563EB"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="13"
                                    Background="#EFF6FF"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <TextBlock Text="▣"
                                           Foreground="#2563EB"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Active Products" Foreground="#64748B"/>
                                <TextBlock x:Name="txtActiveProducts"
                                           Text="8"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#9333EA"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="13"
                                    Background="#FAF5FF"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <TextBlock Text="◇"
                                           Foreground="#9333EA"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Monthly Sales" Foreground="#64748B"/>
                                <TextBlock x:Name="txtMonthlySales"
                                           Text="₱0.00"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#EA580C"
                                           Margin="0,8,0,0"/>
                            </StackPanel>

                            <Border Width="44"
                                    Height="44"
                                    CornerRadius="13"
                                    Background="#FEF3C7"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <TextBlock Text="⌁"
                                           Foreground="#EA580C"
                                           FontSize="22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- ALERTS -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32"
                                            Height="32"
                                            CornerRadius="8"
                                            Background="#FEE2E2">
                                        <TextBlock Text="⚠"
                                                   Foreground="#EF4444"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="Low Stock Alerts"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="12,7,0,0"/>
                                </StackPanel>

                                <Border Background="#FEE2E2"
                                        CornerRadius="10"
                                        Padding="8,3"
                                        HorizontalAlignment="Right">
                                    <TextBlock x:Name="txtLowStockCount"
                                               Text="2 items"
                                               Foreground="#EF4444"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="lowStockPanel">
                                <Border Background="#FEF2F2"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        Margin="0,5">
                                    <Grid>
                                        <TextBlock Text="Sardines in Tomato Sauce"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="8 left"
                                                   Foreground="Red"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>

                                <Border Background="#FEF2F2"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        Margin="0,5">
                                    <Grid>
                                        <TextBlock Text="Cream-O Cookies"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="5 left"
                                                   Foreground="Red"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32"
                                            Height="32"
                                            CornerRadius="8"
                                            Background="#FEF3C7">
                                        <TextBlock Text="◴"
                                                   Foreground="#F59E0B"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="Expiring in 30 Days"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Margin="12,7,0,0"/>
                                </StackPanel>

                                <Border Background="#FEF3C7"
                                        CornerRadius="10"
                                        Padding="8,3"
                                        HorizontalAlignment="Right">
                                    <TextBlock x:Name="txtExpiringCount"
                                               Text="1 items"
                                               Foreground="#F59E0B"
                                               FontSize="12"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>

                            <StackPanel x:Name="expiringPanel">
                                <Border Background="#FFFBEB"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        Margin="0,5">
                                    <Grid>
                                        <TextBlock Text="Fresh Milk 1L"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="5/1/2026"
                                                   Foreground="#EA580C"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- QUICK NAVIGATION AND RECENT TRANSACTIONS -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="390"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}"
                            Height="260">
                        <StackPanel>
                            <TextBlock Text="Quick Navigation"
                                       FontWeight="Bold"
                                       Margin="0,0,0,16"/>

                            <Button Content="🛒   Point of Sale                                      →"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,4"
                                    Click="POS_Click"/>

                            <Button Content="◇   Inventory                                           →"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,4"
                                    Click="Inventory_Click"/>

                            <Button Content="▣   Transactions                                      →"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,4"
                                    Click="Transactions_Click"/>

                            <Button Content="♙   Users                                                →"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,4"
                                    Click="Users_Click"/>

                            <Button Content="◇   Categories                                        →"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Left"
                                    Margin="0,4"
                                    Click="Categories_Click"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource CardStyle}"
                            Height="260">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <TextBlock Text="Recent Transactions"
                                           FontWeight="Bold"
                                           VerticalAlignment="Top"/>

                                <Button Content="View all →"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#16A34A"
                                        HorizontalAlignment="Right"
                                        Click="Transactions_Click"/>
                            </Grid>

                            <StackPanel x:Name="recentTransactionsPanel"
                                        Grid.Row="1"
                                        VerticalAlignment="Center">
                                <TextBlock Text="No transactions yet"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"
                                           Margin="0,70,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- OTHER PAGE AREA -->
        <Grid x:Name="PagePanel"
              Grid.Column="1"
              Background="#F3F4F6"
              Visibility="Collapsed">
            <ContentControl x:Name="MainContent"/>
        </Grid>
    </Grid>
</Window>